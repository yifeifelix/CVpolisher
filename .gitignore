# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files - ignore all except the example template
.env*
!.env.local.example

# vercel
.vercel

# local data
/data/*.db
/data/*.db-journal

# certificates
/certs/*.key
/certs/*.cert
/certs/*.pem

# google credentials
google-credentials.json

# internal docs (not for public repo)
PROJECT_SUMMARY.md

# word documents (test files / downloaded outputs)
*.docx
~$*.docx

# claude code local settings
.claude/settings.local.json
.playwright-mcp/

# typescript
*.tsbuildinfo
next-env.d.ts
