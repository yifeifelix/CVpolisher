# CV Polisher - AI Provider Configuration
# Copy this file to .env.local and fill in your credentials.
# At least ONE provider must be configured.

# --- OpenRouter ---
# Note: If your system already has OPENROUTER_API_KEY set (e.g. from Claude Code),
# use CV_OPENROUTER_API_KEY to override it for this project.
CV_OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODELS=anthropic/claude-sonnet-4,anthropic/claude-haiku-4.5,anthropic/claude-opus-4

# --- AWS Bedrock ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
BEDROCK_MODELS=anthropic.claude-sonnet-4-20250514-v1:0,anthropic.claude-haiku-4-5-20251001-v1:0

# --- Google Vertex AI ---
# Point to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_REGION=us-central1
GOOGLE_MODELS=claude-sonnet-4@20250514,claude-haiku-4-5@20251001

# --- Server ---
PORT=3443
HOST=0.0.0.0
